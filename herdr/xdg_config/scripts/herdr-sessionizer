#!/usr/bin/env bash
# herdr-sessionizer — fuzzy-pick a project/worktree directory, then create or
# resume a Herdr workspace for it. A Herdr port of bin/tmux-sessionizer.
#
# Wired up in herdr/xdg_config/config.toml as a type="pane" keybind so fzf
# renders in a real pane TTY. Switching between existing workspaces is handled
# separately by Herdr's built-in workspace_picker (prefix+ctrl+j).
set -uo pipefail

# 1. Pick a directory: explicit arg, or fzf over project + worktree dirs.
if [[ $# -eq 1 ]]; then
  selected=$1
else
  selected=$({
    find ~/dev -mindepth 1 -maxdepth 2 -type d 2>/dev/null
    find ~/dev/worktrees -maxdepth 3 -name .git -type f -exec dirname {} \; 2>/dev/null
  } | sort -u | fzf --reverse --border=rounded --border-label=' open / resume project ')
fi
[[ -n ${selected:-} ]] || exit 0

# 2. Workspace name = sanitized basename (mirrors tmux-sessionizer session names).
name=$(basename "$selected" | tr . _)

# 3. Create-or-resume: focus an existing workspace with that label, else create.
id=$(herdr workspace list \
       | jq -r --arg n "$name" '.result.workspaces[] | select(.label == $n) | .workspace_id' \
       | head -n1)

if [[ -n $id ]]; then
  herdr workspace focus "$id"
else
  herdr workspace create --cwd "$selected" --label "$name" --focus
fi
